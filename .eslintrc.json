{
    "env": {
        "browser": true,
        "es2020": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended"
    ],
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 11,
        "sourceType": "module"
    },
    "plugins": [
        "react"
    ],
    "rules": {
        "no-empty": 1,
        "no-alert": 1,
        "no-func-assign": 2,
        "no-irregular-whitespace": 2,
        "no-unexpected-multiline": 2,
        "use-isnan": 2,
        "no-else-return": 2,
        "no-empty-function": 2,
        "no-empty-pattern": 2,
        "no-eq-null": 2,
        "no-eval": 2,
        "no-floating-decimal": 2,
        "no-global-assign": 2,
        "no-implicit-coercion": 2,
        "no-implicit-globals": 2,
        "no-invalid-this": 2,
        "no-loop-func": 2,
        "no-magic-numbers": 2,
        "no-multi-spaces": 2,
        "no-param-reassign": 2,
        "no-redeclare": 2,
        "no-self-assign": 2,
        "no-unused-labels": 2,
        "no-useless-catch": 2,
        "no-useless-escape": 2,
        "no-delete-var": 2,
        "no-shadow-restricted-names": 2,
        "no-undef": 2,
        "no-unused-vars": 2,
        "array-bracket-newline": 2,
        "array-bracket-spacing": 2,
        "array-element-newline": 2,
        "block-spacing": 2,
        "brace-style": 2,
        "comma-dangle": 2,
        "comma-spacing": 2,
        "comma-style": 2,
        "computed-property-spacing": 2,
        "eol-last": 2,
        "func-call-spacing": 2,
        "function-call-argument-newline": 2,
        "function-paren-newline": 2,
        "indent": ["error", 2],
        "jsx-quotes": 2,
        "key-spacing": 2,
        "keyword-spacing": 2,
        "linebreak-style": 2,
        "new-parens": 2,
        "no-mixed-spaces-and-tabs": 2,
        "no-multiple-empty-lines": 2,
        "no-trailing-spaces": 2,
        "no-whitespace-before-property": 2,
        "one-var-declaration-per-line": 2,
        "operator-linebreak": 2,
        "sort-vars": 2,
        "arrow-body-style": 2,
        "arrow-parens": 2,
        "arrow-spacing": 2,
        "no-class-assign": 2,
        "no-confusing-arrow": 2,
        "no-const-assign": 2,
        "no-dupe-class-members": 2,
        "no-new-symbol": 2
    }
}
